{
  "name": "@o2n/core",
  "version": "0.1.0",
  "description": "Obsidian vaultをNotionへ移行するo2nのコアロジック（scanner/converter/migrator/state）",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TK-WFL/o2n.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/TK-WFL/o2n#readme",
  "bugs": "https://github.com/TK-WFL/o2n/issues",
  "keywords": ["obsidian", "notion", "migration", "markdown"],
  "main": "./dist/index.js",
